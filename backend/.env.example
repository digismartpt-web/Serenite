# ============================================================
# Sérénité – Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer .env dans git
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de données PostgreSQL ────────────────────────────────
# Variables individuelles (utilisées par lib/database.ts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=serenite
DB_USER=serenite_user
DB_PASSWORD=CHANGE_ME_secure_password_here
DB_POOL_MAX=20

# Alternative : URL complète (commentez les variables ci-dessus si vous utilisez ceci)
# DATABASE_URL=postgresql://serenite_user:password@localhost:5432/serenite

# ── Sécurité JWT ──────────────────────────────────────────────
# OBLIGATOIRE : chaîne aléatoire d'au moins 64 caractères
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_at_least_64_random_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=30d

# ── Application ───────────────────────────────────────────────
APP_URL=https://serenite.app

# ── CORS ──────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules)
# En développement, laisser vide = toutes origines acceptées
CORS_ORIGIN=https://serenite.app,https://www.serenite.app

# ── Email ─────────────────────────────────────────────────────
MAIL_FROM=noreply@serenite.app

# Provider Resend (recommandé)
RESEND_API_KEY=re_CHANGE_ME

# Provider SMTP (alternative)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=CHANGE_ME

# ── Logs ──────────────────────────────────────────────────────
# 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info
